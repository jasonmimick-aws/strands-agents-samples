# Datadog Configuration
DD_ENV=development
DD_SERVICE=strands-demo-agent
DD_API_KEY=your_datadog_api_key_here
DD_APP_KEY=your_datadog_app_key_here
DD_SITE=datadoghq.com

# LLM Observability Configuration
DD_LLMOBS_ML_APP=strands-demo-agent
DD_LLMOBS_AGENTLESS_ENABLED=1

# Langfuse Configuration (if using Langfuse)
LANGFUSE_PUBLIC_KEY=your_langfuse_public_key_here
LANGFUSE_SECRET_KEY=your_langfuse_secret_key_here
LANGFUSE_HOST=https://cloud.langfuse.com

# Model Configuration
# Specify your preferred model here
MODEL_NAME=amazon.titan-text-express-v1
